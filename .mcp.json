{
  "mcpServers": {
    "isaac-sim": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "../isaac-sim-mcp",
        "run",
        "isaac_mcp/server.py"
      ],
      "env": {}
    },
    "ros-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "ros-mcp",
        "--transport=stdio"
      ],
      "env": {}
    }
  }
}