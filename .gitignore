# 데이터 출력 (용량 큼)
data/
*.bag
*.db3

# 캐시
__pycache__/
*.pyc
.cache/

# 환경설정 로컬
.env
*.local

# 스크린샷
*.png
*.jpg

# AppImage 바이너리 (용량 큼, QUICKSTART.md에 다운로드 링크 있음)
*.AppImage

# Claude 설정 — settings.local.json은 다른 환경 세팅용으로 버전 관리에 포함
!.claude/settings.local.json

# 프로젝트 메모리 — 다른 환경 세팅용으로 버전 관리에 포함
# .memory/

# OMC runtime state (per-session, not tracked)
.omc/sessions/
.omc/logs/
.omc/notepad.md
.omc/project-memory.json
# Exclude runtime subdirs under state/ but allow tracked state files
.omc/state/checkpoints/
.omc/state/sessions/
.omc/state/agent-replay-*.jsonl
.omc/state/hud-stdin-cache.json
.omc/state/ralplan-state.json
.omc/state/mission-state.json
.omc/state/subagent-tracking.json
